{
  "name": "ghostwire",
  "version": "0.1.42",
  "description": "GhostWire — OSINT workbench: sock puppet manager, notes, tool launcher, and entity graph for OSINT investigations.",
  "main": "./out/main/index.js",
  "author": "Michael Morin",
  "license": "MIT",
  "build": {
    "appId": "com.ghostwire.osint",
    "productName": "GhostWire",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "icon.png",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/sql.js/dist/*.wasm"
    ],
    "win": {
      "icon": "icon.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "GhostWire",
      "include": "build/installer.nsh"
    },
    "mac": {
      "icon": "icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "icon": "icon.png",
      "target": "AppImage"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AsleepCoffee",
        "repo": "Ghostwire",
        "releaseType": "release"
      }
    ]
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win --publish never",
    "release": "electron-vite build && electron-builder --win --publish always",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.5",
    "electron-updater": "^6.8.9",
    "exifr": "^7.1.3",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.0",
    "sql.js": "^1.12.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
